# TronGrid API Key（https://www.trongrid.io/）
TRONGRID_API_KEY=

# 数据库文件路径
DB_PATH=./data/tron-mpc.db

# --- mpcium MPC 签名服务 ---
# NATS 消息队列地址
MPC_NATS_URL=nats://127.0.0.1:4222

# Event initiator 私钥文件路径
MPC_KEY_PATH=./event_initiator.key

# MPC 签名超时时间（毫秒）
MPC_SIGN_TIMEOUT_MS=60000

# --- 日志配置 ---
# 日志文件目录
LOG_DIR=./logs

# 日志文件名前缀（生成文件格式：{PREFIX}-YYYY-MM-DD.jsonl）
LOG_FILE_PREFIX=app

# 日志文件保留天数（超过此天数的旧文件将被自动删除）
LOG_RETENTION_DAYS=30
